{
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
        "outDir": "./node_modules/.tmp/tsconfig.node",
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "strict": true
    },
    "include": [
        "vite.config.ts",
        "api/**/*.ts",
        "server/**/*.ts",
        "src/lib/rMarkdownSyntax.ts"
    ]
}
